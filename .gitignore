# AMS is the AI tooling repository; the no-AI-footprint rule applies to target
# repos AMS seeds, not to AMS itself. AMS's own .claude/skills/ is committed
# (those are the AMS-only skills users discover when working in this repo).
# Only ephemeral Claude Code session artifacts are excluded.

# Claude Code session worktrees (per-session ephemeral)
.claude/worktrees/

# AMS-side run logs and artifact directories
logs/*.jsonl
logs/.run-*/

# npm / Python local installs (local-only, not committed)
node_modules/
package-lock.json
scripts/learn-codebase/.venv/
scripts/learn-codebase/__pycache__/

# Build artifacts — do not commit (large native binaries)
audit-cli/dist/
audit-cli/node_modules/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
